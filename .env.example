# The committed config/models.json uses these env-var references instead of raw API keys.
# Put real values in your shell profile, password manager, or an uncommitted .env file.
AZURE_FOUNDRY_TECH_API_KEY=
COSINE_API_KEY=

# Optional self-hosted Mem0 OSS memory extension.
# Keeps server/data/key machine-local. Automatic recall is bounded and project-scoped;
# writes happen only via explicit /mem0-remember or mem0_memory add requests.
# Check setup with /mem0-status and /mem0-doctor.
# MEM0_OSS_URL=http://127.0.0.1:8888
# MEM0_OSS_API_KEY=replace-with-local-mem0-api-key
# MEM0_USER_ID=replace-with-optional-local-user-id
